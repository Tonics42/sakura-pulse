<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <Resource Include="Resources\sakura_bg.jpg"/>
    <Resource Include="Resources\app_icon.ico"/>
  </ItemGroup>

  <!-- Prevent WinForms global-using from polluting WPF namespace -->
  <ItemGroup>
    <Using Remove="System.Windows.Forms"/>
    <Using Remove="System.Drawing"/>
  </ItemGroup>

  <PropertyGroup>
    <ApplicationIcon>Resources\app_icon.ico</ApplicationIcon>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>ProcessAnalyzerPro</RootNamespace>
    <AssemblyTitle>ProcessAnalyzerPro</AssemblyTitle>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>

</Project>
